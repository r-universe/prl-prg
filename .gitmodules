[submodule ".registry"]
	path = .registry
	url = https://github.com/prl-prg/prl-prg.r-universe.dev
	branch = HEAD
[submodule "genthat"]
	path = genthat
	url = https://github.com/PRL-PRG/genthat
[submodule "imputesrcref"]
	path = imputesrcref
	url = https://github.com/PRL-PRG/imputesrcref
[submodule "injectr"]
	path = injectr
	url = https://github.com/PRL-PRG/injectr
[submodule "mutator"]
	path = mutator
	url = https://github.com/PRL-PRG/mutator
[submodule "sxpdb"]
	path = sxpdb
	url = https://github.com/PRL-PRG/sxpdb
